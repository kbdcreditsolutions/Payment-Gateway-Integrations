DATABASE_URL="postgresql://user:password@localhost:5432/payment_gateway?schema=public"

# 32-byte hex key used to encrypt the Razorpay key_secret at rest (AES-256-GCM).
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=""

# Session signing secret for admin login cookies (JWT via jose).
# Generate: openssl rand -hex 32
SESSION_SECRET=""

# Bootstrap admin login (first-run only; change the password after logging in).
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme123"

# App base URL.
APP_URL="http://localhost:3000"
